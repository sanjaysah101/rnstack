{
  "name": "rnstack",
  "private": true,
  "version": "0.1.0",
  "description": "A batteries-included, mobile-first Expo + Turborepo React Native monorepo starter (NativeWind v5, RN Reusables, TanStack Query).",
  "scripts": {
    "start": "turbo run start",
    "lint": "turbo run lint",
    "lint:unsafe": "biome check . --write --unsafe",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=create-rnstack && changeset publish",
    "prepare": "husky"
  },
  "keywords": [
    "react-native",
    "expo",
    "monorepo",
    "turborepo",
    "nativewind",
    "react-native-reusables",
    "starter",
    "rnstack"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sanjaysah101/rnstack"
  },
  "author": "Sanjay Kumar Sah",
  "license": "ISC",
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.9.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@changesets/cli": "^2.31.0",
    "@repo/config": "workspace:*",
    "husky": "9.1.7",
    "turbo": "2.10.0",
    "typescript": "6.0.3"
  }
}
